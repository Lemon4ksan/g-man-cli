# G-MAN Daemon (g-mand) Configuration
STEAM_USER=your_steam_username
STEAM_PASS=your_steam_password
STEAM_SHARED_SECRET=your_steam_shared_secret_for_2fa
STEAM_IDENTITY_SECRET=your_steam_identity_secret_for_confirmations
STEAM_DEVICE_ID=your_steam_device_id
STEAM_STORAGE_PATH=storage.json
STEAM_ENABLE_ACHIEVEMENTS="false"
STEAM_MAFILE_PATH=""

# Comma-separated list of trusted SteamIDs allowed to execute admin chat commands
STEAM_TRUSTED_IDS=76561198000000000,76561198000000001

# Connection Manager proxy URL (SOCKS5/HTTP)
STEAM_PROXY_CM=socks5://user:pass@host:port

# Comma-separated list of WebAPI proxy URLs for rotation
STEAM_PROXIES_WEB=http://host1:port,http://host2:port

# External Services APIs
STEAM_TRADER_API_KEY=your_steam_trader_api_key
BPTF_API_KEY=your_backpack_tf_api_key
BPTF_USER_TOKEN=your_backpack_tf_user_token
CRIT_API_KEY=your_crit_api_key
CRIT_STREAM_URL=https://events.pricedb.io/event-stream
MPTF_API_KEY=your_marketplace_tf_api_key

# Local Data Storage Paths
GMAN_CONFIG_PATH=config.json
GMAN_APP_ID=440
GMAN_CONTEXT_ID=2

# Unix Socket
GMAN_SOCKET_PATH=""
GMAN_IPC_NET=""
GMAN_IPC_ADDR=""

# Initial online status of the bot on logon (default: 1)
# Options: 0 (Offline), 1 (Online), 2 (Busy), 3 (Away), 4 (Snooze), 7 (Invisible)
# Alternatively, you can use string names: online, busy, away, snooze, invisible, offline
STEAM_PERSONA_STATE=1

# Optional global variable
GMAN_ENV_PATH=".env"
